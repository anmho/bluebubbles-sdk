{
  "name": "@anmho/bluebubbles-sdk",
  "version": "0.1.2",
  "description": "TypeScript SDK for the BlueBubbles Server REST API",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "scripts": {
    "spec:download": "curl -L 'https://documenter.gw.postman.com/api/collections/765844/UV5RnfwM?environment=765844-a726906e-f1b7-4919-83d5-e740cd155ddb&segregateAuth=true&versionTag=latest' -o spec/bluebubbles.postman.json",
    "spec:convert": "npx postman-to-openapi -s spec/bluebubbles.postman.json -o spec/bluebubbles.openapi.yaml",
    "spec:refresh": "npm run spec:download && npm run spec:convert",
    "generate": "npx openapi-typescript-codegen --input spec/bluebubbles.openapi.yaml --output ./src --client fetch --useOptions --name BlueBubblesClient --postfixServices Service",
    "build": "npm run generate && tsc",
    "build:from-postman": "npm run spec:refresh && npm run build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish --access public",
    "release:publish": "npm run build && npx changeset publish --access public",
    "prepack": "npm run build"
  },
  "keywords": [
    "bluebubbles",
    "sdk",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "files": [
    "dist",
    "README.md"
  ],
  "bugs": {
    "url": "https://github.com/anmho/bluebubbles-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anmho/bluebubbles-sdk.git"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.6",
    "openapi-typescript-codegen": "^0.30.0",
    "postman-to-openapi": "^1.7.3",
    "typescript": "^6.0.2"
  }
}
