{
  "name": "bluebubbles-sdk",
  "version": "1.0.0",
  "description": "",
  "main": "./dist/index.js",
  "type": "module",
  "scripts": {
    "spec:download": "curl -L 'https://documenter.gw.postman.com/api/collections/765844/UV5RnfwM?environment=765844-a726906e-f1b7-4919-83d5-e740cd155ddb&segregateAuth=true&versionTag=latest' -o bluebubbles.postman.json",
    "spec:convert": "npx postman2openapi bluebubbles.postman.json -o bluebubbles.openapi.yaml",
    "generate": "npx openapi-typescript-codegen --input bluebubbles.openapi.yaml --output ./src --client fetch --useOptions --name BlueBubblesClient --split --postfixServices Service",
    "build": "npm run spec:download && npm run spec:convert && npm run generate && tsc",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "js-yaml": "^4.1.1",
    "openapi-typescript-codegen": "^0.30.0",
    "postman-to-openapi": "^1.7.3",
    "postman-to-openapi-cli": "^1.1.2",
    "postman2openapi": "^1.2.1",
    "typescript": "^6.0.2"
  }
}
